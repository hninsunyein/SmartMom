{
  "info": {
    "name": "Smart Mom Balancing System",
    "_postman_id": "smart-mom-api-collection",
    "description": "Full API collection for Smart Mom Balancing System. Base URL: http://localhost:5000/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Parent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register/parent", "host": ["{{baseUrl}}"], "path": ["auth", "register", "parent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Sarah Johnson\",\n  \"email\": \"sarah@example.com\",\n  \"phone\": \"09123456789\",\n  \"age\": 32,\n  \"password\": \"yourpassword\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register Advisor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register/advisor", "host": ["{{baseUrl}}"], "path": ["auth", "register", "advisor"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. May Thu Win\",\n  \"email\": \"dr.may@example.com\",\n  \"phone\": \"09123456789\",\n  \"specialty\": \"Child Nutrition\",\n  \"licenseNumber\": \"MN-12345-2023\",\n  \"experienceYears\": 8,\n  \"password\": \"yourpassword\",\n  \"availability\": [\n    { \"dayOfWeek\": \"monday\", \"startTime\": \"09:00\", \"endTime\": \"12:00\" },\n    { \"dayOfWeek\": \"monday\", \"startTime\": \"14:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": \"wednesday\", \"startTime\": \"09:00\", \"endTime\": \"12:00\" },\n    { \"dayOfWeek\": \"friday\", \"startTime\": \"09:00\", \"endTime\": \"12:00\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Login (Parent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@test.com\",\n  \"password\": \"password\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  console.log('✅ Token saved');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.environment.set('userId', res.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (Advisor)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"advisor@test.com\",\n  \"password\": \"password\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  console.log('✅ Advisor token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.resetToken) {",
                  "  pm.environment.set('resetToken', res.resetToken);",
                  "  console.log('Reset token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👶 Children",
      "item": [
        {
          "name": "Get All Children",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/children", "host": ["{{baseUrl}}"], "path": ["children"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.length > 0) {",
                  "  pm.environment.set('childId', res.data[0].id);",
                  "  console.log('childId saved:', res.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Child",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/children", "host": ["{{baseUrl}}"], "path": ["children"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suu Suu\",\n  \"dateOfBirth\": \"2021-03-15\",\n  \"gender\": \"female\",\n  \"bloodType\": \"O+\",\n  \"allergies\": \"Peanuts\",\n  \"medicalConditions\": \"\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.environment.set('childId', res.data.id);",
                  "  console.log('childId saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Child by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/children/{{childId}}", "host": ["{{baseUrl}}"], "path": ["children", "{{childId}}"] }
          }
        },
        {
          "name": "Update Child",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/children/{{childId}}", "host": ["{{baseUrl}}"], "path": ["children", "{{childId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suu Suu Updated\",\n  \"allergies\": \"None\"\n}"
            }
          }
        },
        {
          "name": "Delete Child",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/children/{{childId}}", "host": ["{{baseUrl}}"], "path": ["children", "{{childId}}"] }
          }
        }
      ]
